  "stacks": {
    "go-api-flutter-contracts": {
      "description": "Go API + Flutter app + shared contracts workspace",
      "components": [
        {
          "run_checks": true,
          "path": "api",
          "template": "go-service",
          "install_deps": true,
          "project_name": "{{stack_name}}-api"
        },
        {
          "run_checks": true,
          "path": "mobile",
          "template": "flutter-app",
          "install_deps": true,
          "project_name": "{{stack_name}}-mobile"
        },
        {
          "run_checks": false,
          "path": "contracts",
          "template": "shared-contracts",
          "install_deps": false,
          "project_name": "{{stack_name}}-contracts"
        }
      ]
    },
    "db-react-worker": {
      "description": "DB API + React web + Python worker + shared contracts",
      "components": [
        {
          "run_checks": true,
          "path": "api",
          "template": "db-api-service",
          "install_deps": true,
          "project_name": "{{stack_name}}-api"
        },
        {
          "run_checks": true,
          "path": "web",
          "template": "react-vite-web",
          "install_deps": true,
          "project_name": "{{stack_name}}-web"
        },
        {
          "run_checks": true,
          "path": "worker",
          "template": "python-worker",
          "install_deps": true,
          "project_name": "{{stack_name}}-worker"
        },
        {
          "run_checks": false,
          "path": "contracts",
          "template": "shared-contracts",
          "install_deps": false,
          "project_name": "{{stack_name}}-contracts"
        }
      ]
    },
    "library-pack": {
      "description": "Reusable module trio: Python module + TypeScript library + Go module",
      "components": [
        {
          "run_checks": true,
          "path": "python",
          "template": "python-module",
          "install_deps": true,
          "project_name": "{{stack_name}}-py"
        },
        {
          "run_checks": true,
          "path": "typescript",
          "template": "typescript-library",
          "install_deps": true,
          "project_name": "{{stack_name}}-ts"
        },
        {
          "run_checks": true,
          "path": "go",
          "template": "go-module",
          "install_deps": true,
          "project_name": "{{stack_name}}-go"
        }
      ]
    }
  }
